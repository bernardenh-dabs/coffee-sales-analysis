      "source": [
        "# src/simulation.py\n",
        "def simulate_base(row):\n",
        "    region = row['region']\n",
        "\n",
        "    if region == \"Ashanti\":\n",
        "        strength = 0.30\n",
        "    elif region == \"Greater Accra\":\n",
        "        strength = 0.26\n",
        "    elif region in [\"Central\",\"Western\"]:\n",
        "        strength = 0.22\n",
        "    else:\n",
        "        strength = 0.12\n",
        "\n",
        "    npp_loss = strength * 0.65\n",
        "    ndc_loss = strength * 0.35\n",
        "\n",
        "    return {\n",
        "        'BASE': strength,\n",
        "        'NPP_new': max(row['NPP'] - npp_loss, 0),\n",
        "        'NDC_new': max(row['NDC'] - ndc_loss, 0)\n",
        "    }"
      ],
      "metadata": {
        "id": "XuN6zwTuyL3g"
      },
      "execution_count": 113,
      "outputs": []
