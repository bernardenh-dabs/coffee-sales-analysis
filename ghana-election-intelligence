        "def simulate_base_advanced(row):\n",
        "\n",
        "    # Base strength by region\n",
        "    if row['region'] == \"Ashanti\":\n",
        "        base_strength = 0.28\n",
        "    elif row['region'] == \"Greater Accra\":\n",
        "        base_strength = 0.25\n",
        "    elif row['region'] in [\"Central\",\"Western\"]:\n",
        "        base_strength = 0.22\n",
        "    else:\n",
        "        base_strength = 0.12\n",
        "\n",
        "    # Kennedy pulls more from NPP\n",
        "    npp_loss = base_strength * 0.65\n",
        "    ndc_loss = base_strength * 0.35\n",
        "\n",
        "    return pd.Series({\n",
        "        'BASE': base_strength,\n",
        "        'NPP_new': max(row['NPP'] - npp_loss, 0),\n",
        "        'NDC_new': max(row['NDC'] - ndc_loss, 0)\n",
        "    })"
      ],
