      "source": [
        "import streamlit as st\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "\n",
        "# Load data\n",
        "df = pd.read_csv(\"/content/sample_data/ghana_elections_full_5cycles.csv\")\n",
        "\n",
        "# Pivot\n",
        "pivot = df.pivot_table(\n",
        "    index=['year','region','constituency'],\n",
        "    columns='party',\n",
        "    values='vote_share'\n",
        ").reset_index().fillna(0)\n",
        "\n",
        "# Add swing margin\n",
        "pivot['swing_margin'] = abs(pivot['NDC'] - pivot['NPP'])\n",
        "\n",
        "# Simulate BASE\n",
        "def simulate(row):\n",
        "    if row['region'] == \"Ashanti\":\n",
        "        base = 0.30\n",
        "    elif row['region'] == \"Greater Accra\":\n",
        "        base = 0.26\n",
        "    elif row['region'] in [\"Central\",\"Western\"]:\n",
        "        base = 0.22\n",
        "    else:\n",
        "        base = 0.12\n",
        "\n",
        "    return pd.Series({\n",
        "        \"BASE\": base,\n",
        "        \"NPP_new\": row['NPP'] - base*0.65,\n",
        "        \"NDC_new\": row['NDC'] - base*0.35\n",
        "    })\n",
        "\n",
        "sim = pivot.apply(simulate, axis=1)\n",
        "pivot = pd.concat([pivot, sim], axis=1)\n",
        "\n",
        "# Winner\n",
        "pivot['winner'] = pivot[['NPP_new','NDC_new','BASE']].idxmax(axis=1)\n",
        "\n",
        "# ---------------- STREAMLIT UI ----------------\n",
        "\n",
        "st.title(\"🇬🇭 Ghana Election Intelligence Dashboard\")\n",
        "\n",
        "menu = st.sidebar.selectbox(\n",
        "    \"Select Dashboard\",\n",
        "    [\"National Overview\", \"Regional Analysis\", \"Strategy Targets\"]\n",
        ")\n",
        "\n",
        "# ---------------- DASHBOARD 1 ----------------\n",
        "\n",
        "if menu == \"National Overview\":\n",
        "    st.header(\"📊 National Vote Projection\")\n",
        "\n",
        "    national = pivot[['NPP_new','NDC_new','BASE']].mean().reset_index()\n",
        "    national.columns = [\"Party\", \"Vote Share\"]\n",
        "\n",
        "    fig = px.bar(national, x=\"Party\", y=\"Vote Share\",\n",
        "                 color=\"Party\", title=\"Projected National Vote Share\")\n",
        "\n",
        "    st.plotly_chart(fig)\n",
        "\n",
        "# ---------------- DASHBOARD 2 ----------------\n",
        "\n",
        "elif menu == \"Regional Analysis\":\n",
        "    st.header(\"🗺️ Regional Power Map\")\n",
        "\n",
        "    region_data = pivot.groupby('region')[['NPP_new','NDC_new','BASE']].mean().reset_index()\n",
        "\n",
        "    fig = px.bar(region_data, x=\"region\",\n",
        "                 y=['NPP_new','NDC_new','BASE'],\n",
        "                 title=\"Regional Vote Strength\",\n",
        "                 barmode='group')\n",
        "\n",
        "    st.plotly_chart(fig)\n",
        "\n",
        "# ---------------- DASHBOARD 3 ----------------\n",
        "\n",
        "elif menu == \"Strategy Targets\":\n",
