        "# src/monte_carlo.py\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "def run_simulation(pivot, n_sim=1000):\n",
        "    outcomes = []\n",
        "\n",
        "    for _ in range(n_sim):\n",
        "        temp = pivot.copy()\n",
        "\n",
        "        noise = np.random.normal(0, 0.02, len(temp))\n",
        "        temp['BASE_sim'] = temp['BASE'] + noise\n",
        "\n",
        "        def winner(row):\n",
        "            votes = {\n",
        "                'NPP': row['NPP_new'],\n",
        "                'NDC': row['NDC_new'],\n",
        "                'BASE': row['BASE_sim']\n",
        "            }\n",
        "            return max(votes, key=votes.get)\n",
        "\n",
        "        temp['winner'] = temp.apply(winner, axis=1)\n",
        "\n",
        "        outcomes.append(temp['winner'].value_counts(normalize=True))\n",
        "\n",
        "    return pd.DataFrame(outcomes).mean()"
