        "import streamlit as st\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import plotly.express as px\n",
        "\n",
        "# ---------------- LOAD DATA ----------------\n",
        "df = pd.read_csv(\"/content/sample_data/ghana_elections_full_5cycles.csv\")\n",
        "\n",
        "pivot = df.pivot_table(\n",
        "    index=['year','region','constituency'],\n",
        "    columns='party',\n",
        "    values='vote_share'\n",
        ").reset_index().fillna(0)\n",
        "\n",
        "pivot['swing_margin'] = abs(pivot['NDC'] - pivot['NPP'])\n",
        "\n",
        "# ---------------- SIDEBAR ----------------\n",
        "st.sidebar.title(\"⚙️ Simulation Controls\")\n",
        "\n",
        "base_strength = st.sidebar.slider(\"BASE Strength\", 0.05, 0.40, 0.20)\n",
        "ken_factor = st.sidebar.slider(\"Kennedy Influence\", 0.5, 0.8, 0.65)\n",
        "\n",
        "# ---------------- SIMULATION ----------------\n",
        "def simulate(row):\n",
        "    region = row['region']\n",
        "\n",
        "    if region == \"Ashanti\":\n",
        "        regional_boost = 1.3\n",
        "    elif region == \"Greater Accra\":\n",
        "        regional_boost = 1.2\n",
        "    elif region in [\"Central\",\"Western\"]:\n",
        "        regional_boost = 1.1\n",
        "    else:\n",
        "        regional_boost = 0.8\n",
        "\n",
        "    base = base_strength * regional_boost\n",
        "\n",
        "    npp_loss = base * ken_factor\n",
        "    ndc_loss = base * (1 - ken_factor)\n",
        "\n",
        "    return pd.Series({\n",
        "        \"BASE\": base,\n",
        "        \"NPP_new\": max(row['NPP'] - npp_loss, 0),\n",
        "        \"NDC_new\": max(row['NDC'] - ndc_loss, 0)\n",
        "    })\n",
        "\n",
        "sim = pivot.apply(simulate, axis=1)\n",
        "pivot = pd.concat([pivot, sim], axis=1)\n",
        "\n",
        "pivot['winner'] = pivot[['NPP_new','NDC_new','BASE']].idxmax(axis=1)\n",
        "\n",
        "# ---------------- UI ----------------\n",
        "st.title(\"🇬🇭 Ghana Election Intelligence System\")\n",
        "\n",
        "menu = st.sidebar.selectbox(\n",
        "    \"Select Dashboard\",\n",
        "    [\"National Overview\", \"Regional Analysis\", \"Strategy Engine\", \"Trend Analysis\"]\n",
        ")\n",
        "\n",
        "# ---------------- DASHBOARD 1 ----------------\n",
        "if menu == \"National Overview\":\n",
        "    st.header(\"📊 National Projection\")\n",
        "\n",
        "    national = pivot[['NPP_new','NDC_new','BASE']].mean().reset_index()\n",
        "    national.columns = [\"Party\",\"Vote Share\"]\n",
        "\n",
        "    fig = px.bar(national, x=\"Party\", y=\"Vote Share\", color=\"Party\")\n",
        "    st.plotly_chart(fig)\n",
        "\n",
        "    st.write(\"### Winner Distribution\")\n",
        "    st.write(pivot['winner'].value_counts())\n",
        "\n",
        "# ---------------- DASHBOARD 2 ----------------\n",
        "elif menu == \"Regional Analysis\":\n",
        "    st.header(\"🗺️ Regional Power Map\")\n",
        "\n",
        "    region_data = pivot.groupby('region')[['NPP_new','NDC_new','BASE']].mean().reset_index()\n",
        "\n",
        "    fig = px.bar(\n",
        "        region_data,\n",
        "        x=\"region\",\n",
        "        y=['NPP_new','NDC_new','BASE'],\n",
        "        barmode='group'\n",
        "    )\n",
        "    st.plotly_chart(fig)\n",
        "\n",
        "    # Bubble map (pseudo-map)\n",
        "    fig2 = px.scatter(\n",
        "        region_data,\n",
        "        x=\"NPP_new\",\n",
        "        y=\"NDC_new\",\n",
        "        size=\"BASE\",\n",
        "        color=\"region\",\n",
        "        title=\"Political Space Map\"\n",
        "    )\n",
        "    st.plotly_chart(fig2)\n",
        "\n",
        "# ---------------- DASHBOARD 3 ----------------\n",
        "elif menu == \"Strategy Engine\":\n",
        "    st.header(\"🎯 Target Constituencies\")\n",
        "\n",
        "    targets = pivot[\n",
        "        (pivot['BASE'] > base_strength) &\n",
        "        (pivot['swing_margin'] < 0.1)\n",
        "    ]\n",
        "\n",
        "    st.dataframe(targets[['region','constituency','BASE','swing_margin']])\n",
        "\n",
        "    fig = px.scatter(\n",
        "        targets,\n",
        "        x=\"swing_margin\",\n",
        "        y=\"BASE\",\n",
        "        color=\"region\",\n",
        "        hover_data=['constituency'],\n",
        "        title=\"Target Strategy Map\"\n",
        "    )\n",
        "    st.plotly_chart(fig)\n",
        "\n",
        "# ---------------- DASHBOARD 4 ----------------\n",
        "elif menu == \"Trend Analysis\":\n",
        "    st.header(\"📈 Historical Trends\")\n",
        "\n",
        "    trend = df.groupby(['year','party'])['vote_share'].mean().reset_index()\n",
        "\n",
        "    fig = px.line(\n",
        "        trend,\n",
        "        x=\"year\",\n",
        "        y=\"vote_share\",\n",
        "        color=\"party\",\n",
        "        markers=True\n",
        "    )\n",
        "    st.plotly_chart(fig)"
      ],
