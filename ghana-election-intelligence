      "source": [
        "# Swing margin\n",
        "pivot['swing_margin'] = abs(pivot['NDC'] - pivot['NPP'])\n",
        "\n",
        "# Swing seats\n",
        "pivot['is_swing'] = pivot['swing_margin'] < 0.1\n",
        "\n",
        "# Stronghold classification\n",
        "pivot['stronghold'] = pivot.apply(\n",
        "    lambda x: 'NPP' if x['NPP'] > 0.6 else ('NDC' if x['NDC'] > 0.6 else 'None'),\n",
        "    axis=1\n",
        ")"
      ],
      "metadata": {
        "id": "7Wlzq-bdsXn8"
      },
      "execution_count": 96,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def simulate_base(row, strength=0.20):\n",
        "    npp_loss = strength * 0.6\n",
        "    ndc_loss = strength * 0.4\n",
        "\n",
        "    return pd.Series({\n",
        "        'BASE': strength,\n",
        "        'NPP_new': max(row['NPP'] - npp_loss, 0),\n",
        "        'NDC_new': max(row['NDC'] - ndc_loss, 0)\n",
        "    })\n",
        "\n",
        "sim = pivot.apply(simulate_base, axis=1)\n",
        "pivot = pd.concat([pivot, sim], axis=1)\n",
        "\n",
        "pivot.head()"
      ],
