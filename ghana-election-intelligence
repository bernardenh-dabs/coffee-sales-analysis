      "source": [
        "# src/features.py\n",
        "def create_features(df):\n",
        "    pivot = df.pivot_table(\n",
        "        index=['year','region','constituency'],\n",
        "        columns='party',\n",
        "        values='vote_share'\n",
        "    ).reset_index().fillna(0)\n",
        "\n",
        "    pivot['swing_margin'] = abs(pivot['NDC'] - pivot['NPP'])\n",
        "    pivot['is_swing'] = pivot['swing_margin'] < 0.1\n",
        "\n",
        "    pivot['stronghold'] = pivot.apply(\n",
        "        lambda x: 'NPP' if x['NPP'] > 0.6 else ('NDC' if x['NDC'] > 0.6 else 'None'),\n",
        "        axis=1\n",
        "    )\n",
        "\n",
        "    return pivot"
